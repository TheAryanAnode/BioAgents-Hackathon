# Nebius Token Factory — OpenAI-compatible inference (MiniMax-M3).
# Without a key the system runs in deterministic demo mode for chat/enrich/report.
# Get credits at https://tokenfactory.nebius.com
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1
NEBIUS_MODEL=MiniMaxAI/MiniMax-M3
NEBIUS_DEEP_MODEL=MiniMaxAI/MiniMax-M3

# LLM rate limits — pipeline stays off by default; chat / enrich / report use the budget.
LLM_USE_IN_PIPELINE=false
LLM_MAX_RPM=30
LLM_TIMEOUT_SECONDS=60
LLM_QUOTA_COOLDOWN_SECONDS=10

# Optional contact email for the PubMed/Entrez API (good etiquette, higher limits)
ENTREZ_EMAIL=

# CRAFT / Emergence MCP — real-world evidence investigation (IDC imaging + PanCancer genomics).
# Leave EMERGENCE_MCP_TOKEN empty to run the investigation in deterministic demo mode
# (no credentials needed). Set it to a valid OAuth bearer token to hit the live
# Snowflake-backed connections via the CRAFT semantic layer.
EMERGENCE_PROJECT_ID=1ac58445-c4ad-49db-b392-17c8003729ef
EMERGENCE_MCP_URL=https://nebius.emergence.ai/mcp
EMERGENCE_MCP_TOKEN=
CRAFT_PANCANCER_CONNECTION=pancancer-atlas-1-1ac58445
CRAFT_IDC_CONNECTION=idc-1ac58445
CRAFT_MAX_QUERIES_PER_INVESTIGATION=6
CRAFT_TIMEOUT_SECONDS=30

# Storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# Ingestion limits (hackathon safety)
MAX_PAPERS=40
MAX_PDF_PAGES=30
MAX_PDF_CHARS=120000

# CORS (frontend dev origin + production — add your Vercel URL)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
