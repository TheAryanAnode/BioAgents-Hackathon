# Google Gemini API key. Without it, the system runs in deterministic demo mode.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Models (override if needed)
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_DEEP_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=text-embedding-004

# Rate limits (free tier ≈5 requests/min for flash). Pipeline uses lexicon/heuristics
# by default so the graph always completes; chat + report use Gemini.
GEMINI_USE_IN_PIPELINE=false
GEMINI_USE_FOR_EMBEDDINGS=false
GEMINI_MAX_RPM=4
GEMINI_TIMEOUT_SECONDS=20
GEMINI_QUOTA_COOLDOWN_SECONDS=55

# Optional contact email for the PubMed/Entrez API (good etiquette, higher limits)
ENTREZ_EMAIL=

# Storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# Ingestion limits (hackathon safety)
MAX_PAPERS=40
MAX_PDF_PAGES=30
MAX_PDF_CHARS=120000

# CORS (frontend dev origin + production — add your Vercel URL)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
